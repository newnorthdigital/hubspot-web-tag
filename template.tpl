___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const log = require('logToConsole');
const injectScript = require('injectScript');
const createQueue = require('createQueue');
const encodeUriComponent = require('encodeUriComponent');
const makeString = require('makeString');

const HSQ_NAME = '_hsq';
const SCRIPT_HOSTS = {
  auto: 'https://js.hs-scripts.com/',
  na1: 'https://js-na1.hs-scripts.com/',
  eu1: 'https://js-eu1.hs-scripts.com/'
};

const actionType = data.actionType;
const enableDebug = data.debug;

const debugLog = (msg) => {
  if (enableDebug) {
    log('HubSpot GTM - ' + msg);
  }
};

const hsq = createQueue(HSQ_NAME);

debugLog('Starting with action type: ' + actionType);

const handleInit = () => {
  const portalId = data.portalId;
  if (!portalId) {
    debugLog('Error: Portal ID is required for initialisation');
    data.gtmOnFailure();
    return;
  }

  const region = data.region || 'auto';
  const host = SCRIPT_HOSTS[region] || SCRIPT_HOSTS.auto;
  const scriptUrl = host + encodeUriComponent(makeString(portalId)) + '.js';

  if (data.contentType) {
    hsq(['setContentType', data.contentType]);
    debugLog('Set content type: ' + data.contentType);
  }

  injectScript(scriptUrl, () => {
    debugLog('Tracking script loaded: ' + scriptUrl);
    data.gtmOnSuccess();
  }, () => {
    debugLog('Tracking script failed to load: ' + scriptUrl);
    data.gtmOnFailure();
  }, 'hubspot-' + makeString(portalId));
};

const handleIdentify = () => {
  const email = data.email;
  if (!email) {
    debugLog('Error: Visitor email is required for identify');
    data.gtmOnFailure();
    return;
  }

  const traits = {};
  traits.email = email;

  const rows = data.customProperties || [];
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (row && row.key) {
      traits[row.key] = row.value;
    }
  }

  hsq(['identify', traits]);
  debugLog('Identified visitor (' + rows.length + ' extra properties)');
  data.gtmOnSuccess();
};

const handlePageView = () => {
  if (data.setPath) {
    if (!data.path) {
      debugLog('Error: Virtual path is required when setPath is enabled');
      data.gtmOnFailure();
      return;
    }
    hsq(['setPath', data.path]);
    debugLog('Set virtual path: ' + data.path);
  }

  hsq(['trackPageView']);
  debugLog('Tracked page view');
  data.gtmOnSuccess();
};

const handleConsent = () => {
  const consentAction = data.consentAction || 'doNotTrack';
  hsq([consentAction]);
  debugLog('Pushed consent action: ' + consentAction);
  data.gtmOnSuccess();
};

if (actionType === 'init') {
  handleInit();
} else if (actionType === 'identify') {
  handleIdentify();
} else if (actionType === 'page') {
  handlePageView();
} else if (actionType === 'consent') {
  handleConsent();
} else {
  debugLog('Unknown action type: ' + actionType);
  data.gtmOnFailure();
}


