___TESTS___

scenarios:
- name: Init - loads tracking script with auto region
  code: |-
    const mockData = {
      actionType: 'init',
      portalId: '1234567',
      region: 'auto',
      contentType: '',
      debug: false
    };

    mock('injectScript', function(url, onSuccess, onFailure, cacheToken) {
      onSuccess();
    });

    runCode(mockData);

    assertApi('injectScript').wasCalled();
    assertApi('gtmOnSuccess').wasCalled();
- name: Init - uses EU1 host when region is eu1
  code: |-
    const mockData = {
      actionType: 'init',
      portalId: '1234567',
      region: 'eu1',
      contentType: '',
      debug: false
    };

    let capturedUrl = '';
    mock('injectScript', function(url, onSuccess, onFailure, cacheToken) {
      capturedUrl = url;
      onSuccess();
    });

    runCode(mockData);

    assertThat(capturedUrl).isEqualTo('https://js-eu1.hs-scripts.com/1234567.js');
    assertApi('gtmOnSuccess').wasCalled();
